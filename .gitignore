# Data (downloaded + preprocessed at runtime — never committed)
data/

# Training artifacts (regenerated by src/train.py)
outputs/*.keras
outputs/*.h5
outputs/train_log.txt
# Note: outputs/metrics.json, outputs/history.json and the assets/*.png figures
# ARE committed so the reported results are reproducible/visible on GitHub.

# Kaggle credentials — never commit
kaggle.json
.kaggle/

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.ipynb_checkpoints/

# OS / editor
.DS_Store
.vscode/
.idea/
